# === GCP Configurations ===
# Ganti dengan Project ID GCP Anda
GCP_PROJECT_ID="your-gcp-project-id"
# Path ke file JSON service account (pastikan file asli ada di .gitignore)
GOOGLE_APPLICATION_CREDENTIALS="./gcp-service-account.json"
GCP_BIGQUERY_DATASET="your_dataset_name"
GCP_BIGQUERY_TABLE="your_table_name"
# Bucket GCS untuk temporary staging BigQuery streaming
GCS_TEMP_BUCKET="your-gcs-temp-bucket"

# === Kafka Configurations ===
# Hostname 'kafka' merujuk pada nama service di docker-compose
KAFKA_BOOTSTRAP_SERVERS="kafka:29092" 
KAFKA_TOPIC="idx_sector_ticks"

# === Spark Configurations ===
SPARK_APP_NAME="RealTimeIDXProcessor"
# SPARK_MASTER tidak perlu di-set di sini — diatur via command docker-compose (--master)
# Folder internal container untuk menyimpan state streaming
SPARK_CHECKPOINT_DIR="/tmp/spark-checkpoints/idx_stock"

# === App Logic & Scheduling ===
# Interval penarikan data (detik)
FETCH_INTERVAL_SECONDS=60

# === Producer Tuning ===
# Delay antar request ticker untuk menghindari rate limit Yahoo Finance (detik)
YFINANCE_DELAY_SECONDS=0.5