{
  "__inputs": [],
  "__requires": [],
  "title": "Pipeline Overview",
  "uid": "pipeline-overview",
  "panels": [
    {
      "title": "Messages Sent Total",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
      "targets": [
        {"expr": "idx_messages_sent_total", "legendFormat": "total"}
      ]
    },
    {
      "title": "Messages Per Second",
      "type": "graph",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
      "targets": [
        {"expr": "rate(idx_messages_sent_total[1m])", "legendFormat": "rate"}
      ]
    },
    {
      "title": "Last Batch Messages",
      "type": "singlestat",
      "gridPos": {"x": 0, "y": 6, "w": 4, "h": 4},
      "targets": [{"expr": "idx_batch_messages"}]
    },
    {
      "title": "Tickers Succeeded",
      "type": "singlestat",
      "gridPos": {"x": 4, "y": 6, "w": 4, "h": 4},
      "targets": [{"expr": "idx_tickers_succeeded"}]
    },
    {
      "title": "Fetch Errors Total",
      "type": "singlestat",
      "gridPos": {"x": 8, "y": 6, "w": 4, "h": 4},
      "targets": [{"expr": "idx_fetch_errors_total"}]
    },
    {
      "title": "Messages by Ticker",
      "type": "table",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 8},
      "targets": [
        {"expr": "idx_messages_sent_total", "legendFormat": "{{ticker}}"}
      ]
    }
  ],
  "schemaVersion": 27,
  "version": 1
}
